# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=vetkb
POSTGRES_PASSWORD=vetkb_secret
POSTGRES_DB=vetkb

# Backend
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
ADMIN_EMAIL=admin@vetkb.local
ADMIN_PASSWORD=admin123

# OpenAI (LLM + TTS for voice agent)
OPENAI_API_KEY=

# Deepgram (STT for voice agent)
DEEPGRAM_API_KEY=

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# YandexGPT (for text chat agent)
YANDEX_GPT_API_KEY=
YANDEX_GPT_FOLDER_ID=
YANDEX_GPT_MODEL=yandexgpt-lite/latest

# LiveKit (voice agent infrastructure)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880

# Voice Agent
EMBEDDING_MODEL=intfloat/multilingual-e5-large
TTS_VOICE=ash
TTS_MODEL=gpt-4o-mini-tts
TTS_SPEED=1.15
LLM_MODEL=gpt-4o-mini
DEFAULT_COMPANY_ID=1
